<?xml version="1.0" encoding="utf-8"?>
<!-- 
  Local Build Configuration Template
  
  Copy this file to 'local.build.props' and update the paths to match your local environment.
  The 'local.build.props' file is git-ignored so each contributor can have their own paths.
-->
<Project>
	<PropertyGroup>
		<!-- 
			Mono Game Path
			Point this to your Mono build of Schedule I (if you have one)
		-->
		<MonoGamePath>D:\SteamLibrary\steamapps\common\Schedule I_alternate</MonoGamePath>
		
		<!-- 
			IL2CPP Game Path
			Point this to your IL2CPP build of Schedule I (if you have one)
		-->
		<Il2CppGamePath>D:\SteamLibrary\steamapps\common\Schedule I_public</Il2CppGamePath>
		
		<!-- Optional: Custom deployment paths -->
        <!-- Runtime-specific paths take precedence over shared client/server overrides -->
        <!-- If not specified, defaults to $(GamePath)\Mods -->
        <!-- <MonoClientDeploymentPath>C:\Path\To\MonoClient\Mods</MonoClientDeploymentPath> -->
        <!-- <MonoServerDeploymentPath>C:\Path\To\MonoServer\Mods</MonoServerDeploymentPath> -->
        <!-- <Il2CppClientDeploymentPath>C:\Path\To\Il2CppClient\Mods</Il2CppClientDeploymentPath> -->
        <!-- <Il2CppServerDeploymentPath>C:\Path\To\Il2CppServer\Mods</Il2CppServerDeploymentPath> -->
        <!-- <ClientDeploymentPath>C:\Path\To\AllClients\Mods</ClientDeploymentPath> -->
        <!-- <ServerDeploymentPath>C:\Path\To\AllServers\Mods</ServerDeploymentPath> -->

	</PropertyGroup>
</Project>
