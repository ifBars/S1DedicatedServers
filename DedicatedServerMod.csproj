<Project Sdk="Microsoft.NET.Sdk">
	<!-- Import CI and local build configuration -->
	<Import Project="ci.build.props" Condition="Exists('ci.build.props')" />
	<Import Project="local.build.props" Condition="Exists('local.build.props')" />
	
	<PropertyGroup>
		<EffectiveConfiguration>$(Configuration)</EffectiveConfiguration>
		<EffectiveConfiguration Condition="'$(EffectiveConfiguration)' == '' Or '$(EffectiveConfiguration)' == 'Debug' Or '$(EffectiveConfiguration)' == 'Release'">Documentation</EffectiveConfiguration>
		<TargetFramework>netstandard2.1</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<RootNamespace>DedicatedServerMod</RootNamespace>
		<LangVersion>default</LangVersion>
		<NeutralLanguage>en-US</NeutralLanguage>
		<Configurations>Mono_Client;Mono_Server;Il2cpp_Client;Il2cpp_Server;Documentation</Configurations>
		<AutomateLocalDeployment Condition="'$(AutomateLocalDeployment)' == '' and '$(CI)' == 'true'">false</AutomateLocalDeployment>
		<AutomateLocalDeployment Condition="'$(AutomateLocalDeployment)' == '' and '$(CI)' != 'true'">true</AutomateLocalDeployment>
	</PropertyGroup>

	<PropertyGroup Condition="'$(EffectiveConfiguration)'=='Mono_Client' Or '$(EffectiveConfiguration)'=='Mono_Server' Or '$(EffectiveConfiguration)'=='Documentation'">
		<TargetFramework>netstandard2.1</TargetFramework>
	</PropertyGroup>

	<PropertyGroup Condition="'$(EffectiveConfiguration)'=='Il2cpp_Client' Or '$(EffectiveConfiguration)'=='Il2cpp_Server'">
		<TargetFramework>net6.0</TargetFramework>
	</PropertyGroup>
	
	<!-- NuGet Package References -->
	<ItemGroup>
		<PackageReference Include="Krafs.Publicizer" Version="2.3.0">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
	</ItemGroup>
	
	<!-- MelonLoader references (common to all configurations) -->
	<ItemGroup Condition="'$(EffectiveConfiguration)'=='Mono_Client' Or '$(EffectiveConfiguration)'=='Mono_Server' Or '$(EffectiveConfiguration)'=='Documentation'">
		<Reference Include="MelonLoader">
			<HintPath>$(MelonLoaderPath)\MelonLoader.dll</HintPath>
		</Reference>
		<Reference Include="0Harmony">
			<HintPath>$(MelonLoaderPath)\0Harmony.dll</HintPath>
		</Reference>
	</ItemGroup>
	
	<ItemGroup Condition="'$(EffectiveConfiguration)'=='Il2cpp_Client' Or '$(EffectiveConfiguration)'=='Il2cpp_Server'">
		<Reference Include="MelonLoader">
			<HintPath>$(MelonLoaderPath)\MelonLoader.dll</HintPath>
		</Reference>
		<Reference Include="0Harmony">
			<HintPath>$(MelonLoaderPath)\0Harmony.dll</HintPath>
		</Reference>
		<Reference Include="Il2CppInterop.Runtime">
			<HintPath>$(MelonLoaderPath)\Il2CppInterop.Runtime.dll</HintPath>
		</Reference>
	</ItemGroup>

	<ItemGroup Condition="'$(EffectiveConfiguration)'=='Documentation'">
		<Content Include="$(ManagedPath)\Newtonsoft.Json.dll">
			<Link>Newtonsoft.Json.dll</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

