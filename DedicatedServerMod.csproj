		<MelonLoaderPath Condition="'$(MelonLoaderAssembliesPath)' == ''">$(GamePath)\MelonLoader\net35</MelonLoaderPath>
		<ModsPath>$(GamePath)\Mods</ModsPath>
		<DefineConstants>MONO;CLIENT</DefineConstants>
		<AssemblyName>DedicatedServerMod_Mono_Client</AssemblyName>
		<OutputPath>bin\$(EffectiveConfiguration)\</OutputPath>
		<!-- Use custom deployment path if specified, otherwise use default ModsPath -->
		<DeploymentPath Condition="'$(ClientDeploymentPath)' != ''">$(ClientDeploymentPath)</DeploymentPath>
		<DeploymentPath Condition="'$(ClientDeploymentPath)' == ''">$(ModsPath)</DeploymentPath>
	</PropertyGroup>

